// A "JS but not JS" sample: two records with method fields, a higher-order
// greet function with a conditional, and a final expression that is the
// program's result.

let alice = {
  name: "Alice",
  age: 30,
  greet: fn(self) { "hi, I'm " + self.name }
}

let bob = {
  name: "Bob",
  age: 25,
  greet: fn(self) { "yo, I'm " + self.name }
}

let greetOlder = fn(a, b) {
  if a.age > b.age then a.greet() + " (older)" else b.greet() + " (older)"
}

greetOlder(alice, bob)
