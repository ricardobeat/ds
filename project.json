{
  "langrev": "1",
  "warnings": ["no-unused"],
  "dependency-search-paths": ["lib"],
  "dependencies": [],
  "version": "0.1.0",
  "sources": ["src/**"],
  "test-sources": ["test/**"],
  "build-dir": "build",
  "output": "build",
  "targets": {
    "engine": {
      "type": "executable"
    },
    "release": {
      "type": "executable",
      "opt": "Os",
      "optsize": "tiny",
      "optlevel": "more",
      "memory-env": "tiny",
      "fp-math": "relaxed",
      "strip-unused": true
    }
  },
  "cpu": "generic",
  "opt": "O2"
}
