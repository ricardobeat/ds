{
  "langrev": "1",
  "warnings": ["no-unused"],
  "dependency-search-paths": ["lib"],
  "dependencies": [],
  "version": "0.1.0",
  "sources": [],
  "test-sources": ["test/**"],
  "build-dir": "build",
  "output": "build",
  "targets": {
    "engine": {
      "type": "executable",
      "sources": ["src/**"]
    },
    "release": {
      "type": "executable",
      "sources": ["src/**"],
      "opt": "Os",
      "optsize": "tiny",
      "optlevel": "more",
      "memory-env": "tiny",
      "fp-math": "relaxed",
      "strip-unused": true
    },
    "libengine": {
      "type": "static-lib",
      "sources": [
        "src/main.c3", "src/parser.c3", "src/formatter.c3",
        "src/compiler.c3", "src/chunk.c3", "src/vm.c3", "src/embed.c3"
      ]
    },
    "host-example": {
      "type": "executable",
      "sources": [
        "src/main.c3", "src/parser.c3", "src/formatter.c3",
        "src/compiler.c3", "src/chunk.c3", "src/vm.c3", "src/embed.c3",
        "example/src/main.c3"
      ]
    },
    "ds": {
      "type": "executable",
      "dependencies": ["milktea", "glaze", "xray"],
      "sources": [
        "src/main.c3", "src/parser.c3", "src/formatter.c3",
        "src/compiler.c3", "src/chunk.c3", "src/vm.c3", "src/embed.c3",
        "example/milktea/main.c3"
      ]
    },
    "bench": {
      "type": "executable",
      "sources": [
        "src/main.c3", "src/parser.c3", "src/formatter.c3",
        "src/compiler.c3", "src/chunk.c3", "src/vm.c3", "src/embed.c3",
        "bench/main.c3"
      ]
    }
  },
  "cpu": "generic",
  "opt": "O2"
}
